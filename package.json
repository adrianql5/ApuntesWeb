    "assets:prune": "python3 scripts/prune_unused_images.py --delete"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.1",
    "astro": "^5.6.1",
    "katex": "^0.16.27",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.2"
  }
