---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const quickLinks = [
	{ href: '/ApuntesWeb/segundo/primer-cuatrimestre/', label: '2º · 1C' },
	{ href: '/ApuntesWeb/segundo/segundo-cuatrimestre/', label: '2º · 2C' },
	{ href: '/ApuntesWeb/tercero/primer-cuatrimestre/', label: '3º · 1C' },
	{ href: '/ApuntesWeb/tercero/segundo-cuatrimestre/', label: '3º · 2C' },
];
---

<div class="app-header">
	<div class="title-wrapper sl-flex">
		<SiteTitle />
	</div>
	<div class="app-header__search sl-flex print:hidden">
		{shouldRenderSearch && <Search />}
	</div>
	<nav class="app-header__nav print:hidden" aria-label="Accesos rápidos">
		{
			quickLinks.map((link) => (
				<a href={link.href} class="app-header__nav-link">
					{link.label}
				</a>
			))
		}
	</nav>
	<div class="app-header__actions print:hidden">
		<div class="sl-hidden md:sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<div class="sl-hidden lg:sl-flex">
			<LanguageSelect />
		</div>
	</div>
</div>

<style>
	@layer starlight.core {
		.app-header {
			display: flex;
			align-items: center;
			gap: 0.8rem;
			width: 100%;
			min-width: 0;
		}

		.title-wrapper {
			flex: 0 0 auto;
			min-width: 0;
		}

		.app-header__search {
			flex: 0 1 13rem;
			min-width: min(100%, 11rem);
		}

		.app-header__actions,
		.social-icons {
			display: flex;
			gap: 1rem;
			align-items: center;
		}

		.app-header__actions {
			flex: 0 0 auto;
			margin-inline-start: auto;
		}

		.social-icons::after {
			content: '';
			height: 2rem;
			border-inline-end: 1px solid var(--sl-color-gray-5);
		}

		.app-header__nav {
			display: flex;
			gap: 0.55rem;
			align-items: center;
			flex: 1 1 auto;
			min-width: 0;
			overflow-x: auto;
			scrollbar-width: none;
			padding-bottom: 0.05rem;
		}

		.app-header__nav::-webkit-scrollbar {
			display: none;
		}

		.app-header__nav-link {
			flex: 0 0 auto;
			border-radius: 999px;
			padding: 0.38rem 0.72rem;
			font-size: var(--sl-text-xs);
			font-weight: 700;
			line-height: 1;
			text-decoration: none;
		}

		@media (max-width: 72rem) {
			.title-wrapper {
				display: none;
			}
		}

		@media (max-width: 50rem) {
			.app-header {
				display: flex;
				align-items: center;
				gap: 0;
				min-height: 2.5rem;
			}

			.title-wrapper {
				display: flex;
				flex: 1 1 auto;
				align-items: center;
				min-width: 0;
				padding-inline-end: 3.25rem;
			}

			.app-header__search,
			.app-header__nav,
			.app-header__actions {
				display: none;
			}

			.title-wrapper :global(.site-title) {
				max-width: 100%;
				font-size: 0.84rem;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
		}

		@media (max-width: 37rem) {
			.title-wrapper {
				padding-inline-end: 3rem;
			}

			.title-wrapper :global(.site-title) {
				font-size: 0.78rem;
			}
		}
	}
</style>

<script is:inline>
	(() => {
		if (typeof window === 'undefined') return;

		if (window.__appHeaderHeightSyncSetup) {
			window.__appHeaderHeightSyncSetup();
			return;
		}

		let observedHeader = null;
		let resizeObserver = null;
		let frameId = 0;
		let lastHeight = 0;

		const getHeader = () => document.querySelector('.page > header.header');

		const syncHeaderHeight = () => {
			const header = getHeader();
			if (!header) return;
			const nextHeight = Math.ceil(header.getBoundingClientRect().height);
			if (!nextHeight || nextHeight === lastHeight) return;
			lastHeight = nextHeight;
			document.documentElement.style.setProperty('--sl-nav-height', `${nextHeight}px`);
		};

		const scheduleSync = () => {
			cancelAnimationFrame(frameId);
			frameId = requestAnimationFrame(syncHeaderHeight);
		};

		const attachObserver = () => {
			const header = getHeader();
			if (!header || header === observedHeader) {
				scheduleSync();
				return;
			}

			resizeObserver?.disconnect();
			resizeObserver = new ResizeObserver(scheduleSync);
			resizeObserver.observe(header);
			observedHeader = header;
			scheduleSync();
		};

		window.__appHeaderHeightSyncSetup = attachObserver;

		window.addEventListener('resize', scheduleSync, { passive: true });
		window.addEventListener('orientationchange', scheduleSync, { passive: true });
		window.addEventListener('load', scheduleSync, { once: true });
		document.addEventListener('astro:page-load', attachObserver);
		document.fonts?.ready?.then(scheduleSync);

		attachObserver();
	})();
</script>
