---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const quickLinks = [
	{ href: '/ApuntesWeb/segundo/primer-cuatrimestre/', label: '2º · 1C' },
	{ href: '/ApuntesWeb/segundo/segundo-cuatrimestre/', label: '2º · 2C' },
	{ href: '/ApuntesWeb/tercero/primer-cuatrimestre/', label: '3º · 1C' },
	{ href: '/ApuntesWeb/tercero/segundo-cuatrimestre/', label: '3º · 2C' },
];
---

<div class="app-header">
	<div class="title-wrapper sl-flex">
		<SiteTitle />
	</div>
	<div class="app-header__search sl-flex print:hidden">
		{shouldRenderSearch && <Search />}
	</div>
	<nav class="app-header__nav print:hidden" aria-label="Accesos rápidos">
		{
			quickLinks.map((link) => (
				<a href={link.href} class="app-header__nav-link">
					{link.label}
				</a>
			))
		}
	</nav>
	<div class="app-header__actions print:hidden">
		<div class="sl-hidden md:sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<div class="sl-hidden lg:sl-flex">
			<LanguageSelect />
		</div>
	</div>
</div>

<style>
	@layer starlight.core {
		.app-header {
			display: grid;
			grid-template-columns: auto minmax(14rem, 1fr) auto auto;
			align-items: center;
			gap: 0.85rem;
			height: auto;
			min-width: 0;
		}

		.title-wrapper {
			overflow: clip;
			padding: 0.25rem;
			margin: -0.25rem;
			min-width: 0;
			grid-area: title;
		}

		.app-header__search {
			min-width: 0;
			grid-area: search;
		}

		.app-header__actions,
		.social-icons {
			gap: 1rem;
			align-items: center;
		}

		.app-header__actions {
			grid-area: actions;
		}

		.social-icons::after {
			content: '';
			height: 2rem;
			border-inline-end: 1px solid var(--sl-color-gray-5);
		}

		.app-header__nav {
			display: flex;
			gap: 0.55rem;
			align-items: center;
			min-width: 0;
			overflow-x: auto;
			scrollbar-width: none;
			padding-bottom: 0.05rem;
			grid-area: nav;
		}

		.app-header__nav::-webkit-scrollbar {
			display: none;
		}

		.app-header__nav-link {
			flex: 0 0 auto;
			border-radius: 999px;
			padding: 0.38rem 0.72rem;
			font-size: var(--sl-text-xs);
			font-weight: 700;
			line-height: 1;
			text-decoration: none;
		}

		@media (min-width: 50rem) {
			.app-header {
				grid-template-columns: minmax(11.5rem, 13.5rem) minmax(0, 1fr) auto;
				grid-template-areas: 'search nav actions';
			}

			.title-wrapper {
				display: none;
			}
		}

		@media (max-width: 50rem) {
			.app-header {
				grid-template-columns: minmax(0, 1fr) auto;
				grid-template-areas:
					'title actions'
					'search search'
					'nav nav';
				align-items: stretch;
				column-gap: 0.55rem;
				row-gap: 0.42rem;
			}

			.app-header__actions {
				justify-self: end;
			}
		}
	}
</style>
